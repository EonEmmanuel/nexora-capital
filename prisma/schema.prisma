generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPPORT
  ANALYST
  FINANCE
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
  RESTRICTED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum PoolStatus {
  DRAFT
  UPCOMING
  OPEN
  FULL
  PAUSED
  CLOSED
  ARCHIVED
}

enum RiskLevel {
  CONSERVATIVE
  MODERATE
  BALANCED
  AGGRESSIVE
  HIGH_RISK
}

enum AllocationStatus {
  CREATED
  PAYMENT_PENDING
  PAYMENT_DETECTED
  UNDER_REVIEW
  ACTIVE
  PAUSED
  MATURED
  WITHDRAWAL_PENDING
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  DETECTED
  CONFIRMING
  COMPLETED
  UNDER_REVIEW
  FAILED
  EXPIRED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  ALLOCATION
  PROFIT
  LOSS
  FEE
  PROFIT_DISTRIBUTION
  WITHDRAWAL
  REFUND
  ADJUSTMENT
}

enum WithdrawalStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  PAYMENT
  WITHDRAWAL
  SECURITY
  POOL
  SYSTEM
}

model User {
  id                String          @id @default(cuid())
  firstName         String
  lastName          String
  email             String          @unique
  emailVerified     DateTime?
  passwordHash      String?
  avatarUrl         String?
  phone             String?
  country           String?
  timezone          String?
  preferredCurrency String          @default("USDT")
  status            UserStatus      @default(PENDING)
  role              UserRole        @default(USER)
  kycStatus         KycStatus       @default(NOT_STARTED)
  twoFactorEnabled  Boolean         @default(false)
  referralCode      String          @unique
  referredById      String?
  referredBy        User?           @relation("UserReferrals", fields: [referredById], references: [id])
  referrals         User[]          @relation("UserReferrals")
  allocations       Allocation[]
  payments          Payment[]
  transactions      Transaction[]
  withdrawals       Withdrawal[]
  notifications     Notification[]
  tickets           SupportTicket[]
  auditLogs         AuditLog[]      @relation("ActorAuditLogs")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lastLoginAt       DateTime?
}

model TradingPool {
  id                    String            @id @default(cuid())
  slug                  String            @unique
  name                  String
  shortDescription      String
  fullDescription       String
  strategyDescription   String
  riskLevel             RiskLevel
  status                PoolStatus        @default(DRAFT)
  featured              Boolean           @default(false)
  baseCurrency          String            @default("USDT")
  minimumAllocation     Decimal           @db.Decimal(20, 8)
  maximumAllocation     Decimal           @db.Decimal(20, 8)
  totalCapacity         Decimal           @db.Decimal(20, 8)
  currentlyAllocated    Decimal           @default(0) @db.Decimal(20, 8)
  managementFeePercent  Decimal           @db.Decimal(8, 4)
  performanceFeePercent Decimal           @db.Decimal(8, 4)
  durationDays          Int?
  flexibleDuration      Boolean           @default(false)
  startDate             DateTime?
  endDate               DateTime?
  heroImage             String?
  icon                  String?
  displayOrder          Int               @default(0)
  allocations           Allocation[]
  performance           PoolPerformance[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model PoolPerformance {
  id                       String      @id @default(cuid())
  poolId                   String
  pool                     TradingPool @relation(fields: [poolId], references: [id])
  date                     DateTime
  nav                      Decimal     @db.Decimal(20, 8)
  dailyReturnPercent       Decimal     @db.Decimal(10, 4)
  cumulativeReturnPercent  Decimal     @db.Decimal(10, 4)
  benchmarkReturnPercent   Decimal     @db.Decimal(10, 4)
  drawdownPercent          Decimal     @db.Decimal(10, 4)
  assetsUnderManagement    Decimal     @db.Decimal(20, 8)
  createdAt                DateTime    @default(now())

  @@unique([poolId, date])
}

model Allocation {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  poolId           String
  pool             TradingPool      @relation(fields: [poolId], references: [id])
  reference        String           @unique
  amount           Decimal          @db.Decimal(20, 8)
  currency         String
  status           AllocationStatus @default(CREATED)
  initialValue     Decimal          @db.Decimal(20, 8)
  currentValue     Decimal          @db.Decimal(20, 8)
  realizedProfit   Decimal          @default(0) @db.Decimal(20, 8)
  unrealizedProfit Decimal          @default(0) @db.Decimal(20, 8)
  totalDistributed Decimal          @default(0) @db.Decimal(20, 8)
  payments         Payment[]
  transactions     Transaction[]
  withdrawals      Withdrawal[]
  activatedAt      DateTime?
  maturedAt        DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Payment {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  allocationId     String?
  allocation       Allocation?   @relation(fields: [allocationId], references: [id])
  paymentReference String        @unique
  provider         String
  method           String
  requestedAmount  Decimal       @db.Decimal(20, 8)
  receivedAmount   Decimal?      @db.Decimal(20, 8)
  currency         String
  network          String?
  walletAddress    String?
  transactionHash  String?
  status           PaymentStatus @default(PENDING)
  confirmations    Int           @default(0)
  metadata         Json?
  expiresAt        DateTime?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  allocationId String?
  allocation   Allocation?     @relation(fields: [allocationId], references: [id])
  type         TransactionType
  amount       Decimal         @db.Decimal(20, 8)
  currency     String
  status       String
  reference    String          @unique
  description  String
  metadata     Json?
  createdAt    DateTime        @default(now())
}

model Withdrawal {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id])
  allocationId       String?
  allocation         Allocation?      @relation(fields: [allocationId], references: [id])
  reference          String           @unique
  amount             Decimal          @db.Decimal(20, 8)
  fee                Decimal          @db.Decimal(20, 8)
  netAmount          Decimal          @db.Decimal(20, 8)
  currency           String
  network            String
  destinationAddress String
  transactionHash    String?
  status             WithdrawalStatus @default(REQUESTED)
  rejectionReason    String?
  reviewedById       String?
  requestedAt        DateTime         @default(now())
  reviewedAt         DateTime?
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())
}

model SupportTicket {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  subject      String
  category     String
  priority     String
  status       String
  assignedToId String?
  messages     SupportMessage[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  closedAt     DateTime?
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  authorId  String
  body      String
  internal  Boolean       @default(false)
  createdAt DateTime      @default(now())
}

model Referral {
  id               String   @id @default(cuid())
  referrerId       String
  referredUserId   String   @unique
  conversionStatus String
  rewardAmount     Decimal  @default(0) @db.Decimal(20, 8)
  rewardStatus     String
  createdAt        DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation("ActorAuditLogs", fields: [actorId], references: [id])
  action      String
  entityType  String
  entityId    String?
  description String
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model PaymentWebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([provider, eventId])
}
