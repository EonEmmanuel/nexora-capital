# PostgreSQL connection used by Prisma. docker-compose.yml provides these local defaults.
DATABASE_URL="postgresql://nexora:nexora@localhost:5432/nexora?schema=public"

# Required for signed application session cookies. Replace with a long random value before production.
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Public URL used for links and referral URLs in local development.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Local development payment provider. Keep as mock until a production provider adapter is configured.
PAYMENT_PROVIDER="mock"

# Standard runtime environment.
NODE_ENV="development"
